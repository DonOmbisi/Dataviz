# DataViz Pro Environment Configuration
# Copy this file to .env and fill in your actual values

# ==============================================
# DATABASE CONFIGURATION (Optional)
# ==============================================

# MongoDB Atlas (Recommended)
# Get this from your MongoDB Atlas cluster connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_connection_string_here

# MongoDB Database Name (default: dataviz_pro)
MONGODB_DB_NAME=dataviz_pro

# PostgreSQL (Alternative to MongoDB)
# Format: postgresql://username:password@hostname:port/database_name
# Example: postgresql://user:pass@localhost:5432/dataviz_pro
#DATABASE_URL=

# ==============================================
# AI FEATURES CONFIGURATION (Optional)
# ==============================================

# OpenAI API Key for AI-powered insights and natural language queries
# Get this from: https://platform.openai.com/api-keys
# Format: sk-...
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ==============================================
# SERVER CONFIGURATION (Optional)
# ==============================================

# Streamlit Server Port (default: 8501, recommended: 5000)
STREAMLIT_SERVER_PORT=5000

# Server Address (use 0.0.0.0 for external access, 127.0.0.1 for local only)
STREAMLIT_SERVER_ADDRESS=127.0.0.1

# Server Headless Mode (true for production, false for development)
STREAMLIT_SERVER_HEADLESS=false

# Enable file watcher for auto-reload (development only)
STREAMLIT_SERVER_RUN_ON_SAVE=true

# ==============================================
# APPLICATION CONFIGURATION (Optional)
# ==============================================

# Maximum file upload size in MB (default: 200)
MAX_UPLOAD_SIZE_MB=200

# Default sample size for large datasets (default: 10000)
DEFAULT_SAMPLE_SIZE=10000

# Enable debug mode (true/false)
DEBUG_MODE=false

# Application theme (light/dark/auto)
APP_THEME=dark

# ==============================================
# SECURITY CONFIGURATION (Optional)
# ==============================================

# Secret key for session management (generate a random string)
SECRET_KEY=generate_your_own_secret_key_here

# Enable CORS (true/false) - for API access
ENABLE_CORS=false

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ==============================================
# LOGGING CONFIGURATION (Optional)
# ==============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (leave empty to log to console only)
LOG_FILE=

# ==============================================
# PERFORMANCE CONFIGURATION (Optional)
# ==============================================

# Enable data caching (true/false)
ENABLE_CACHING=true

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# Maximum rows to process without sampling
MAX_ROWS_NO_SAMPLING=50000

# ==============================================
# FEATURE FLAGS (Optional)
# ==============================================

# Enable AI features (true/false)
ENABLE_AI_FEATURES=true

# Enable database features (true/false)
ENABLE_DATABASE_FEATURES=true

# Enable geographic mapping (true/false)
ENABLE_GEO_FEATURES=true

# Enable collaboration features (true/false)
ENABLE_COLLABORATION=true

# Enable advanced analytics (true/false)
ENABLE_ADVANCED_ANALYTICS=true

# ==============================================
# EXAMPLES AND NOTES
# ==============================================

# Example MongoDB Atlas URI:
# MONGODB_URI=mongodb+srv://admin:mypassword@cluster0.abc123.mongodb.net/dataviz_pro?retryWrites=true&w=majority

# Example PostgreSQL URI:
# DATABASE_URL=postgresql://postgres:mypassword@localhost:5432/dataviz_pro

# Example OpenAI API Key:
# OPENAI_API_KEY=sk-proj-abcd1234efgh5678ijkl9012mnop3456qrst7890

# For Replit Deployment:
# - Add these variables to Replit Secrets instead of .env file
# - Use the Secrets tab in your Repl
# - Only add the variables you actually need

# For Local Development:
# - Copy this file to .env
# - Fill in the values you want to use
# - The app works with basic functionality even without these variables

# Security Notes:
# - Never commit your .env file to version control
# - Keep your API keys and database credentials secure
# - Use environment-specific values for different deployments

